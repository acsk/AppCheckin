# SPA Expo Router — DocumentRoot = conteúdo de mobile/dist/
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Bundles Expo (pasta expo-static; não usar _expo na Hostinger)
  RewriteCond %{REQUEST_URI} ^/expo-static/
  RewriteRule ^ - [R=404,L]

  RewriteCond %{REQUEST_URI} ^/fonts/
  RewriteRule ^ - [R=404,L]

  RewriteRule ^ index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
  <FilesMatch "\.(js|css|ttf|woff2?|ico|png|jpg|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# MIME explícito (LiteSpeed / Hostinger)
AddType application/javascript .js
AddType text/css .css
AddType font/ttf .ttf
